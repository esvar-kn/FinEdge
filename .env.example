PORT=3000
NODE_ENV=development

# SQLite database (relative to workspace root)
DB_PATH=src/data/finedge.db

# Automated daily backups
BACKUP_DIR=src/data/backups
BACKUP_KEEP=7

# Legacy JSON store paths — only used by `npm run migrate:json`
USERS_DB_PATH=src/data/users.json
TRANSACTIONS_DB_PATH=src/data/transactions.json

# Financial Rules & Thresholds
SAVINGS_WARNING_THRESHOLD=0.70

# JWT Auth configurations
JWT_SECRET=your_jwt_signing_key_here
JWT_EXPIRES_IN=7d

# AI insights (optional): with no key, /api/transactions/ai-insights returns
# the rule-based insights instead. Get a free key at https://console.groq.com
# GROQ_API_KEY=gsk_...
AI_MODEL=llama-3.3-70b-versatile

# Security hardening
# CORS_ORIGIN=http://localhost:5173   # unset = same-origin only (safest)
AUTH_RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_MS=900000
