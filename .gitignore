# Dependency directories
node_modules/
jspm_packages/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Local environment variables
.env

# Temporary files and OS artifacts
.DS_Store
Thumbs.db
*.tmp
src/data/*.tmp
write_test.txt

# Local data stores (contain user records & password hashes) and their
# backups — never commit these. Covers the SQLite DB (+ WAL/SHM journals),
# the legacy JSON stores, and corrupt-file backups.
src/data/*.json
src/data/*.db
src/data/*.db-wal
src/data/*.db-shm
src/data/backups/
src/data/test-backups/
!src/data/.gitkeep
*.corrupt-*

# Test coverage reports
coverage/
.nyc_output/
